# ── Storefront Environment Variables ──────────────────────────────────────────
# Copy to .env.local and fill in real values. Never commit .env.local.
#
# NOTE: DATABASE_URI and PAYLOAD_SECRET are NOT here — they belong to the
# CMS app only (see apps/cms/.env.example).

# CMS server (Payload) — where the storefront fetches content from
# Development: http://localhost:3001 (run `npm run dev` inside apps/cms/)
# Production:  https://cms.eyesoul.id
NEXT_PUBLIC_CMS_URL=http://localhost:3001

# Public URL of this storefront (used for OG/sitemap canonical URLs)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Maps (Mapbox)
NEXT_PUBLIC_MAP_PROVIDER=mapbox
NEXT_PUBLIC_MAPBOX_TOKEN=

# Analytics (PostHog)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Newsletter (Mailchimp)
MAILCHIMP_API_KEY=
MAILCHIMP_AUDIENCE_ID=
MAILCHIMP_SERVER_PREFIX=

# Email delivery (Resend) — used by the contact form server action
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@eyesoul.id
