# ── CMS Server Environment Variables ──────────────────────────────────────────
# Copy to .env.local and fill in real values. Never commit .env.local.

# Database
DATABASE_URI=postgres://postgres:postgres@localhost:5432/eyesoul_brand

# Payload core (generate a long random string for production)
PAYLOAD_SECRET=replace-with-a-long-random-secret

# The public URL of THIS CMS server (used for SEO plugin URL generation and CORS)
NEXT_PUBLIC_SERVER_URL=http://localhost:3001

# The public URL of the storefront (used by SEO plugin to generate canonical links)
NEXT_PUBLIC_STOREFRONT_URL=http://localhost:3000
